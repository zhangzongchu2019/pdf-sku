APP_ENV=development
DATABASE_URL=postgresql+asyncpg://pdfsku:pdfsku@localhost:5432/pdfsku
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pdf-sku
TUS_UPLOAD_DIR=/home/zzc/pdf-sku/server/data/tus-uploads
JOB_DATA_DIR=/data/jobs
LOG_LEVEL=INFO
JWT_SECRET_KEY=dev-secret-key

# LLM - 默认客户端 (gemini / qwen / openrouter，留空自动选择)
DEFAULT_LLM_CLIENT=

# LLM - Gemini (直连或中转)
GEMINI_API_KEY=
GEMINI_API_BASE=          # 留空用官方直连，填写走中转（如 https://api.laozhang.ai）
GEMINI_MODEL=gemini-2.5-flash

# LLM - Qwen (直连或中转)
QWEN_API_KEY=
QWEN_API_BASE=            # 留空用官方，填写走中转
QWEN_MODEL=qwen-vl-max

# LLM - OpenRouter (通用 OpenAI 兼容)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=         # 如 google/gemini-2.5-flash
