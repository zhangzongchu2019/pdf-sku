APP_ENV=development
DATABASE_URL=postgresql+asyncpg://pdfsku:pdfsku@localhost:5432/pdfsku
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pdf-sku
TUS_UPLOAD_DIR=/home/zzc/pdf-sku/server/data/tus-uploads
JOB_DATA_DIR=/data/jobs
LOG_LEVEL=INFO
JWT_SECRET_KEY=dev-secret-key

# LLM - 默认客户端 (留空则使用第一个注册的 provider)
# Provider 命名: 模型名 (直连) | 模型名.代理名 (代理)
# 例: gemini-2.5-flash.api.laozhang.ai / qwen-vl-max / gemini-2.5-flash.openrouter
DEFAULT_LLM_CLIENT=

# LLM - Gemini (直连或中转)
# 推荐模型: gemini-2.5-flash (性价比最优), gemini-2.5-pro (复杂文档)
GEMINI_API_KEY=
GEMINI_API_BASE=          # 留空用官方直连，填写走中转（如 https://api.laozhang.ai）
GEMINI_MODEL=gemini-2.5-flash

# LLM - Qwen (直连或中转)
# 推荐模型: qwen-vl-max (VLM最强), qwen2.5-vl-72b-instruct (131K上下文)
QWEN_API_KEY=
QWEN_API_BASE=            # 留空用阿里云官方，填写走中转
QWEN_MODEL=qwen-vl-max

# LLM - OpenRouter (通用 OpenAI 兼容，支持多模型)
# 推荐: google/gemini-2.5-flash, qwen/qwen2.5-vl-72b-instruct, deepseek/deepseek-r1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=         # 如 google/gemini-2.5-flash
